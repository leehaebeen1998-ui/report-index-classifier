{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.example/schemas/category-index.schema.json",
  "title": "Report Category Index",
  "type": "object",
  "required": [
    "index_version",
    "scope",
    "column_aliases",
    "forced_url_mapping",
    "campaign_type_rules",
    "group_name_rules",
    "keyword_rules",
    "campaign_name_rules",
    "url_rules",
    "user_corrections",
    "ai_fallback"
  ],
  "properties": {
    "index_version": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "required": ["brand_id"],
      "properties": {
        "brand_id": {
          "type": "string"
        },
        "account_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "column_aliases": {
      "type": "object",
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "forced_url_mapping": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/forcedUrlMapping"
      }
    },
    "campaign_type_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "group_name_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "keyword_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "campaign_name_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "url_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "user_corrections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/userCorrection"
      }
    },
    "ai_fallback": {
      "type": "object",
      "required": ["enabled", "min_confidence"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "min_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "analyze_fields": {
          "type": "array",
          "items": {
            "enum": [
              "landing_page_text",
              "creative_name",
              "ad_text",
              "page_title",
              "meta_description"
            ]
          },
          "default": []
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "forcedUrlMapping": {
      "type": "object",
      "required": ["id", "url", "category"],
      "properties": {
        "id": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "category": {
          "type": "string"
        },
        "include_query": {
          "type": "boolean",
          "default": false
        },
        "memo": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "rule": {
      "type": "object",
      "required": ["id", "field", "match_type", "patterns", "category", "confidence"],
      "properties": {
        "id": {
          "type": "string"
        },
        "field": {
          "enum": [
            "campaign_type",
            "group_name",
            "keyword_name",
            "campaign_name",
            "url"
          ]
        },
        "match_type": {
          "enum": ["exact", "contains", "regex"]
        },
        "patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "category": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "campaign_type_filter": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "memo": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "userCorrection": {
      "type": "object",
      "required": ["id", "category", "evidence", "created_at"],
      "properties": {
        "id": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "evidence": {
          "type": "object",
          "properties": {
            "campaign_type": {
              "type": "string"
            },
            "group_name": {
              "type": "string"
            },
            "keyword_name": {
              "type": "string"
            },
            "campaign_name": {
              "type": "string"
            },
            "url": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "promoted_to_rule_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
